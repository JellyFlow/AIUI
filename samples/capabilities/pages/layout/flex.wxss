.flex-row {
  display: flex;
  flex-direction: row;
}
.flex-column {
  display: flex;
  flex-direction: column;
}
.justify-center {
  justify-content: center;
}
.justify-between {
  justify-content: space-between;
}
.align-center {
  align-items: center;
}
.item {
  width: 44px;
  height: 44px;
  background: linear-gradient(135deg, #1989fa, #0570db);
  color: #ffffff;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 6px;
  border-radius: var(--radius-sm, 8px);
  font-weight: 600;
  box-shadow: 0 2px 4px rgba(25, 137, 250, 0.2);
}

.shorthand-track {
  display: flex;
  flex-direction: row;
  width: 100%;
  gap: 10px;
  box-sizing: border-box;
  padding: var(--spacing-md, 12px);
  border-radius: var(--radius-sm, 8px);
}

.shorthand-item {
  min-width: 0;
  min-height: 88px;
  padding: 10px;
  border-radius: var(--radius-sm, 8px);
  border: 2px solid rgba(17, 163, 97, 0.35);
}

.shorthand-grow-1 {
  flex: 1;
}

.shorthand-grow-2 {
  flex: 2;
}

.shorthand-basis {
  flex: 1 0 64px;
}

.shorthand-code {
  display: block;
  font-size: 13px;
  font-weight: 600;
}

.shorthand-note {
  display: block;
  margin-top: 8px;
  font-size: 12px;
  line-height: 18px;
}

.shorthand-description {
  margin-top: 12px;
}

.shorthand-caption {
  display: block;
  font-size: 13px;
  line-height: 20px;
}
