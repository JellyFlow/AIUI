.container {
  --lottie-page-background: var(--color-background);
  --lottie-surface-background: var(--color-surface);
  --lottie-surface-highlight-background: var(--color-surface-highlight);
  --lottie-text-color: var(--color-text-primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-lg, 20px);
  background-color: var(--lottie-page-background);
  gap: 16px;
}

.page-title {
  font-size: 24px;
  font-weight: bold;
  color: var(--lottie-text-color);
}

.card {
  width: 100%;
  padding: var(--spacing-md, 12px);
  border: var(--border-width-thin, 1px) solid var(--border-color-default, #ddd);
  background-color: var(--lottie-surface-background);
}

.section-title {
  font-size: 18px;
  font-weight: bold;
  color: var(--lottie-text-color);
}

.lottie {
  width: 100%;
  height: 300px;
  border: var(--border-width-thin, 1px) solid var(--border-color-default, #ccc);
}

.lottie-stage {
  width: 100%;
  padding: var(--spacing-md, 12px);
  box-sizing: border-box;
}

.light-stage {
  background-color: var(--lottie-surface-highlight-background);
}

.controls {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 20px;
}
