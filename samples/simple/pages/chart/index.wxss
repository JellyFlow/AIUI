.container {
  --chart-page-background: var(--color-background);
  --chart-page-panel-background: var(--chart-panel-background, var(--color-surface));
  --chart-page-panel-highlight-background: var(--chart-frame-background, var(--color-surface-highlight));
  --chart-text-color: var(--color-text-primary);
  --chart-muted-text-color: var(--color-text-secondary);
  --chart-note-color: var(--color-text-secondary);
  --chart-default-color: var(--chart-color, var(--color-primary));
  --chart-page-frame-background: var(--chart-frame-background, var(--color-surface-highlight));
  --chart-toggle-background: var(--color-primary-40, var(--color-surface-highlight));
  --chart-toggle-text-color: var(--color-primary);
  --chart-page-line-color: var(--chart-page-line-color, #007AFF);
  --chart-page-area-color: var(--chart-page-area-color, #FF3B30);
  --chart-page-pie-color: var(--chart-page-pie-color, #FFCC00);
  --chart-page-strip-line-color: var(--chart-reference-color, #FBC02D);
  padding: 62.5px;
  background-color: var(--chart-page-background);
  flex-direction: column;
}
.page-title,
.title {
  color: var(--chart-text-color);
  font-size: 24px;
  margin-bottom: 20px;
}
.chart-container {
  flex-direction: column;
  margin-bottom: 30px;
  background-color: var(--chart-page-panel-background);
  padding: 10px;
  border-radius: 8px;
}
.chart-title {
  color: var(--chart-text-color);
  font-size: 16px;
  margin-bottom: 10px;
  display: block;
}

.chart-subtitle {
  color: var(--chart-muted-text-color);
  font-size: 13px;
  margin-top: 8px;
  margin-bottom: 6px;
  display: block;
}

.chart-note {
  color: var(--chart-note-color);
  font-size: 12px;
  margin-top: 4px;
  display: block;
}

.flex-row {
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
}
.chart-pie {
  margin: 0 auto;
  display: block;
}
.chart-radar {
  margin: 0 auto;
  display: block;
}

.price-chart-frame {
  width: 350px;
  height: 80px;
  border-radius: 4px;
  margin-bottom: 6px;
}

.mode-row {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.mode-label {
  color: var(--chart-muted-text-color);
  font-size: 12px;
}

.mode-toggle {
  color: var(--chart-toggle-text-color);
  font-size: 12px;
  padding: 4px 8px;
  background-color: var(--chart-toggle-background);
  border-radius: 4px;
}
