<view class="container">
  <view class="page-title">Chart Component</view>

  <view class="card chart-container">
    <text class="chart-title">Line Chart (Axis, Grid, Labels)</text>
    <chart
      type="{{ lineChartProps.type }}"
      series="{{ lineChartProps.series }}"
      data="{{ lineChartProps.data }}"
      width="350"
      height="150"
      class="chart"
      animate="true"
      color="var(--chart-page-line-color, #007AFF)"
      smooth="{{ lineChartProps.smooth }}"
      y-axis="{{ lineChartProps.yAxis }}"
      x-axis="{{ lineChartProps.xAxis }}"
    ></chart>
  </view>

  <view class="card chart-container">
    <text class="chart-title">Area Chart (Axis Title &amp; Grid)</text>
    <chart
      type="{{ areaChartProps.type }}"
      series="{{ areaChartProps.series }}"
      data="{{ areaChartProps.data }}"
      width="350"
      height="120"
      class="chart"
      animate="true"
      color="var(--chart-page-area-color, #FF3B30)"
      smooth="{{ areaChartProps.smooth }}"
      y-axis="{{ areaChartProps.yAxis }}"
      x-axis="{{ areaChartProps.xAxis }}"
    ></chart>
  </view>

  <view class="card chart-container">
    <text class="chart-title">Bar Chart (Vertical &amp; Horizontal)</text>
    <text class="chart-subtitle">Vertical</text>
    <chart
      type="{{ barVerticalChartProps.type }}"
      direction="{{ barVerticalChartProps.direction }}"
      series="{{ barVerticalChartProps.series }}"
      data="{{ barVerticalChartProps.data }}"
      y-axis="{{ barVerticalChartProps.yAxis }}"
      x-axis="{{ barVerticalChartProps.xAxis }}"
      width="350"
      height="250"
      class="chart"
    ></chart>
    <text class="chart-subtitle">Horizontal</text>
    <chart
      type="{{ barHorizontalChartProps.type }}"
      direction="{{ barHorizontalChartProps.direction }}"
      series="{{ barHorizontalChartProps.series }}"
      data="{{ barHorizontalChartProps.data }}"
      y-axis="{{ barHorizontalChartProps.yAxis }}"
      x-axis="{{ barHorizontalChartProps.xAxis }}"
      show-value-labels="true"
      value-label-format="grouped"
      width="350"
      height="250"
      class="chart"
    ></chart>
    <text class="chart-note"
      >Bar now supports axis lines, grid lines, labels, titles, and both
      `direction=&quot;vertical&quot;` and `direction=&quot;horizontal&quot;`.</text
    >
    <text class="chart-note"
      >Use one `series` field or an array with one series object using `yName`.</text
    >
    <text class="chart-note"
      >Built-in `yodaos-sprite-greenonly` renders charts in `outline-only` mode by default.</text
    >
  </view>

  <view class="card chart-container">
    <text class="chart-title">Scatter &amp; Funnel Charts</text>
    <text class="chart-subtitle">Scatter</text>
    <chart
      type="{{ scatterChartProps.type }}"
      series="{{ scatterChartProps.series }}"
      data="{{ scatterChartProps.data }}"
      y-axis="{{ scatterChartProps.yAxis }}"
      x-axis="{{ scatterChartProps.xAxis }}"
      point-size="{{ scatterChartProps.pointSize }}"
      width="350"
      height="220"
      class="chart"
    ></chart>
    <text class="chart-subtitle">Funnel</text>
    <chart
      type="{{ funnelChartProps.type }}"
      data="{{ funnelChartProps.data }}"
      label-key="{{ funnelChartProps.labelKey }}"
      value-key="{{ funnelChartProps.valueKey }}"
      show-conversion="{{ funnelChartProps.showConversion }}"
      width="350"
      height="220"
      class="chart"
    ></chart>
    <text class="chart-note"
      >Scatter uses the chart theme color by default, and supports numeric axes, multi-series
      points, and `point-size`.</text
    >
    <text class="chart-note"
      >Funnel renders stage labels and values inside each block, shows conversion rates on the
      right, and keeps adjacent layers connected with no gap.</text
    >
  </view>

  <view class="chart-container">
    <text class="chart-title">Realtime Style Line (Axis Viewport)</text>
    <view class="mode-row">
      <text class="mode-label">Update Mode: {{ updateMode }}</text>
      <view class="mode-toggle" bindtap="toggleUpdateMode">Toggle</view>
    </view>
    <view class="price-chart-frame">
      <chart
        type="{{ chartProps.type }}"
        series="{{ chartProps.series }}"
        data="{{ chartProps.data }}"
        animate="{{ chartProps.animate }}"
        y-axis="{{ chartProps.yAxis }}"
        x-axis="{{ chartProps.xAxis }}"
        width="{{ priceChartWidth }}"
        height="{{ priceChartHeight }}"
        class="chart"
      ></chart>
    </view>
  </view>

  <view class="chart-container">
    <text class="chart-title">Viewport Scenarios (minimum / maximum)</text>

    <text class="chart-subtitle">Opening (1 / 240)</text>
    <view class="price-chart-frame">
      <chart
        type="{{ intradayWindowSamples.opening.type }}"
        series="{{ intradayWindowSamples.opening.series }}"
        data="{{ intradayWindowSamples.opening.data }}"
        animate="{{ intradayWindowSamples.opening.animate }}"
        y-axis="{{ intradayWindowSamples.opening.yAxis }}"
        x-axis="{{ intradayWindowSamples.opening.xAxis }}"
        width="{{ intradaySampleWidth }}"
        height="{{ intradaySampleHeight }}"
        class="chart"
      ></chart>
    </view>

    <text class="chart-subtitle">Mid Session (120 / 240)</text>
    <view class="price-chart-frame">
      <chart
        type="{{ intradayWindowSamples.midSession.type }}"
        series="{{ intradayWindowSamples.midSession.series }}"
        data="{{ intradayWindowSamples.midSession.data }}"
        animate="{{ intradayWindowSamples.midSession.animate }}"
        y-axis="{{ intradayWindowSamples.midSession.yAxis }}"
        x-axis="{{ intradayWindowSamples.midSession.xAxis }}"
        width="{{ intradaySampleWidth }}"
        height="{{ intradaySampleHeight }}"
        class="chart"
      ></chart>
    </view>

    <text class="chart-subtitle">Full Window (240 / 240)</text>
    <view class="price-chart-frame">
      <chart
        type="{{ intradayWindowSamples.fullWindow.type }}"
        series="{{ intradayWindowSamples.fullWindow.series }}"
        data="{{ intradayWindowSamples.fullWindow.data }}"
        animate="{{ intradayWindowSamples.fullWindow.animate }}"
        y-axis="{{ intradayWindowSamples.fullWindow.yAxis }}"
        x-axis="{{ intradayWindowSamples.fullWindow.xAxis }}"
        width="{{ intradaySampleWidth }}"
        height="{{ intradaySampleHeight }}"
        class="chart"
      ></chart>
    </view>

    <text class="chart-subtitle">Rolling Window (latest 240 / 320)</text>
    <view class="price-chart-frame">
      <chart
        type="{{ intradayWindowSamples.rollingWindow.type }}"
        series="{{ intradayWindowSamples.rollingWindow.series }}"
        data="{{ intradayWindowSamples.rollingWindow.data }}"
        animate="{{ intradayWindowSamples.rollingWindow.animate }}"
        y-axis="{{ intradayWindowSamples.rollingWindow.yAxis }}"
        x-axis="{{ intradayWindowSamples.rollingWindow.xAxis }}"
        width="{{ intradaySampleWidth }}"
        height="{{ intradaySampleHeight }}"
        class="chart"
      ></chart>
    </view>
  </view>

  <view class="card chart-container">
    <text class="chart-title">Pie &amp; Radar Charts (Custom Colors)</text>
    <view class="flex-row">
      <chart
        type="pie"
        series="value"
        data="{{ pieData }}"
        show-percentage="true"
        width="170"
        height="170"
        class="chart-pie"
        color="var(--chart-page-pie-color, #FFCC00)"
      ></chart>
      <chart
        type="radar"
        series="value"
        data="{{ radarData }}"
        label-key="label"
        levels="5"
        show-points="true"
        max="100"
        width="220"
        height="220"
        class="chart-radar"
        color="var(--chart-color, #40ff5e)"
      ></chart>
    </view>
    <text class="chart-note"
      >Pie supports `show-percentage` and renders percentage labels inside segments.</text
    >
    <text class="chart-note"
      >Radar supports `label-key`, `levels`, `show-points`, and `max` for labeled multi-axis
      layouts.</text
    >
  </view>
</view>
