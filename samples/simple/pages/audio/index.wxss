.container {
  display: flex;
  flex-direction: column;
  padding: 20px;
  background-color: #f5f5f7;
}

.page-title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 20px;
  color: #111;
}

.player-card {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 18px;
  background-color: #fff;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  color: #222;
  margin-bottom: 4px;
}

.status-label,
.source-label {
  font-size: 12px;
  color: #666;
  text-transform: uppercase;
}

.status-text,
.source-text,
.hint {
  font-size: 14px;
  color: #333;
}

.source-text {
  word-break: break-all;
}

.controls {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 8px;
  margin-bottom: 8px;
}

.control-button {
  width: 100%;
}
