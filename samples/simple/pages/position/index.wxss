.container {
  flex-direction: column;
  padding: 20px;
}

.section {
  flex-direction: column;
  margin-bottom: 30px;
}

.title {
  font-weight: bold;
  font-size: 20px;
  margin-bottom: 10px;
}

.relative-box {
  width: 200px;
  height: 100px;
  position: relative;
}

.relative-child {
  position: relative;
  top: 20px;
  left: 20px;
  height: 50px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.relative-container {
  position: relative;
  width: 100%;
  height: 150px;
}

.absolute-child1 {
  position: absolute;
  top: 10px;
  left: 10px;
  height: 50px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.absolute-child2 {
  position: absolute;
  bottom: 10px;
  right: 10px;
  height: 50px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.absolute-inset {
  position: absolute;
  inset: 20px;
  display: flex;
  justify-content: center;
  align-items: center;
}
