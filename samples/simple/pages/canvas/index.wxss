.container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 20px;
  margin-bottom: 20px;
}

.canvas {
  width: 96vw;
  height: 75vh;
  background-color: #f0f0f0;
  border: var(--border-width-thin, 1px) solid var(--border-color-default, #ccc);
  border-radius: 16px;
  margin: auto;
  margin-bottom: 20px;
}