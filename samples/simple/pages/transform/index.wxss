.container {
  --transform-page-background: var(--color-background);
  --transform-text-color: var(--color-text-primary);
  --transform-stage-background: var(--color-surface-highlight);
  --transform-box-background: var(--color-primary);
  display: flex;
  flex-direction: column;
  padding: 20px;
  background-color: var(--transform-page-background);
}

.title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 20px;
  display: block;
  color: var(--transform-text-color);
}

.section {
  margin-bottom: 30px;
  justify-content: space-between;
}

.label {
  color: var(--transform-text-color);
  font-size: 16px;
  margin-bottom: 10px;
  display: block;
}

.box-container {
  width: 100px;
  height: 100px;
  background-color: var(--transform-stage-background);
  border: var(--border-width-thin, 1px) dashed var(--border-color-muted, #999);
}

.box {
  width: 60px;
  height: 60px;
  background-color: var(--transform-box-background);
  opacity: 0.8;
}

.translate {
  transform: translate(50px, 20px);
}

.rotate {
  transform: rotate(45deg);
}

.scale {
  transform: scale(1.5, 0.5);
}

.skew {
  transform: skew(30deg, 10deg);
}

.matrix {
  transform: matrix(1, 0.2, 0.2, 1, 0, 0);
}

.multiple {
  transform: translate(20px, 20px) rotate(30deg);
}

.origin-top-left {
  transform: rotate(45deg);
  transform-origin: 0 0;
}
