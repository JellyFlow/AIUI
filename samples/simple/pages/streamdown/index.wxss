.container {
  --streamdown-page-background: var(--color-background);
  --streamdown-surface-background: var(--color-surface);
  --streamdown-text-color: var(--color-text-primary);
  --streamdown-muted-text-color: var(--color-text-secondary);
  --streamdown-button-background: var(--color-primary);
  --streamdown-button-text-color: var(--streamdown-contrast-text-color, #ffffff);
  padding: 40px;
  background-color: var(--streamdown-page-background);
  flex-direction: column;
}

.title {
  color: var(--streamdown-text-color);
  font-size: 28px;
  font-weight: bold;
  margin-bottom: 30px;
}

.section {
  flex-direction: column;
  margin-bottom: 40px;
  background-color: var(--streamdown-surface-background);
  padding: 20px;
  border-radius: 12px;
  border: var(--border-width-thin, 1px) solid var(--border-color-muted, #dee2e6);
}

.section-title {
  color: var(--streamdown-muted-text-color);
  font-size: 14px;
  font-weight: bold;
  text-transform: uppercase;
  margin-bottom: 15px;
  letter-spacing: 1px;
}

.markdown-box {
  background-color: var(--streamdown-surface-background);
  padding: 15px;
  border-radius: 8px;
  min-height: 100px;
}

.btn {
  margin-top: 20px;
  background-color: var(--streamdown-button-background);
  color: var(--streamdown-button-text-color);
  padding: 10px 20px;
  border-radius: 6px;
  text-align: center;
  font-size: 16px;
}
