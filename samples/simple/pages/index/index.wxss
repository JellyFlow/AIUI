.nav-list {
  display: flex;
  flex-direction: column;
}

.category-title {
  font-size: 14px;
  font-weight: bold;
  margin-top: 12px;
  margin-bottom: 12px;
  padding-left: 4px;
}

.nav-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  margin-bottom: 12px;
  box-sizing: border-box;
  width: 100%;
}

.nav-text {
  font-size: 16px;
  font-weight: 500;
}

.nav-arrow {
  font-size: 16px;
}
